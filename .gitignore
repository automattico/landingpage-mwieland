.DS_Store
**/.DS_Store
node_modules/
.env
.env.local
.env.*
!.env.example
__pycache__/
*.pyc
smoke-test.log

# Non-deploy working files
work/tmp/*
!work/tmp/.gitkeep
work/images-source/*
!work/images-source/.gitkeep

# Sensitive host/archive artifacts (keep archive content, but ignore logs/dumps)
archive/host-logs/
archive/**/*.log
archive/**/*.out
archive/**/*.err
archive/**/*.zip
archive/**/*.tar
archive/**/*.tar.gz
